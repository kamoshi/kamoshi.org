<nav class="wiki-tree">
  <ul>
    {% for node in tree recursive %}
    <li>
      {% if node.is_link %}
      <a href="{{ node.href }}"{% if node.is_current %} class="current"{% endif %}>{{ node.name }}</a>
      {% else %}
      <span>{{ node.name }}</span>
      {% endif %}
      {% if node.children %}
      <ul>{{ loop(node.children) }}</ul>
      {% endif %}
    </li>
    {% endfor %}
  </ul>
</nav>
