{% extends "layouts/base.jinja" %}

{% block main %}
<main>
  {{ outline }}
  <article class="article">
    <section class="paper">
      <header>
        <h1 id="top">{{ title }}</h1>
      </header>
      <section class="wiki-article__markdown markdown">
        {{ content }}
      </section>
    </section>
    {% if bibliography %}
    <section class="bibliography">
      <header>
        <h2>Bibliography</h2>
        {% if bibliography.library_path %}
        <a class="icon-btn" href="{{ bibliography.library_path }}" download="bibliography.bib" aria-label="Download BibTeX">
          {% include "assets/lucide/file-down.svg" %}
        </a>
        {% endif %}
      </header>
      <ol>
        {% for item in bibliography.items %}
        <li>{{ item }}</li>
        {% endfor %}
      </ol>
    </section>
    {% endif %}
  </article>
  <aside class="tiles">
    <section class="k-box metadata">
      <h2>Metadata</h2>
      <div>
        {% include "assets/lucide/file-plus-2.svg" %}
        <span class="sr-only">Added</span>
        <time datetime="{{ metadata.date_added_iso }}">{{ metadata.date_added }}</time>
      </div>
      {% if metadata.updated %}
      <div>
        {% include "assets/lucide/file-clock.svg" %}
        <span class="sr-only">Updated</span>
        <time datetime="{{ metadata.updated.date_iso }}">{{ metadata.updated.date }}</time>
      </div>
      <div>
        {% include "assets/lucide/git-graph.svg" %}
        <span class="sr-only">Commit</span>
        <a href="{{ metadata.updated.hash_url }}">{{ metadata.updated.hash }}</a>
      </div>
      {% endif %}
      {% if metadata.tags %}
      <div class="tags">
        {% include "assets/lucide/tag.svg" %}
        <span class="sr-only">Tags</span>
        <ul>
          {% for tag in metadata.tags %}
          <li><a href="/tags/{{ tag }}">{{ tag }}</a></li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}
    </section>
  </aside>
</main>
{% endblock %}
